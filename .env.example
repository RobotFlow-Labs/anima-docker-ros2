ROS_DISTRO=jazzy
ANIMA_PROFILE=desktop
# Use linux/amd64 on Intel Macs. Keep linux/arm64 for Apple Silicon.
DOCKER_PLATFORM=linux/arm64
HOST_NOVNC_PORT=6080
HOST_VNC_PORT=5901
HOST_WEBRTC_PORT=8080
HOST_FOXGLOVE_PORT=8765
SHM_SIZE=1gb
VNC_PASSWORD=
VNC_GEOMETRY=1600x900
ANIMA_HOST_OS=macos
ANIMA_DDS_IMPLEMENTATION=fastrtps
ANIMA_HARDWARE_PROFILE=none
ANIMA_DESKTOP_TRANSPORT=novnc
ANIMA_ENABLE_WEBRTC=0
ANIMA_ENABLE_NOVNC=1
