#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
RobotFlowLabs ANIMA CLI

Usage:
  ./anima up [desktop|dev|sim] [--bind PATH] [--dds fastrtps|cyclonedds] [--hardware none|usb|serial|camera|audio|all] [--transport webrtc|novnc] [--no-open]
  ./anima build [desktop|dev|sim]
  ./anima shell [desktop|dev|sim] [--bind PATH] [--dds fastrtps|cyclonedds] [--hardware none|usb|serial|camera|audio|all] [--transport webrtc|novnc]
  ./anima logs [desktop|dev|sim]
  ./anima stop
  ./anima clean
  ./anima doctor
  ./anima open
  ./anima status [desktop|dev|sim]
  ./anima url
  ./anima env
  ./anima password [show|reset]
  ./anima foxglove [dev|sim] [--bind PATH] [--dds fastrtps|cyclonedds] [--no-open]
  ./anima demo [--force]
  ./anima starter [list|show|install|remove|test] [MODULE_ID] [--force]
  ./anima module [list|show|install|remove|test] [MODULE_ID] [--force]  (alias)
  ./anima import <path>
  ./anima export <path>
  ./anima bake
  ./anima compose <docker compose args...>
  ./anima sync-reference
  ./anima install-cli
  ./anima help

Profiles:
  desktop  default lightweight remote desktop
  dev      desktop plus developer tooling
  sim      dev plus simulation packages

Hardware overlays:
  none     no hardware passthrough (default)
  usb      Linux USB bus access for connected devices
  serial   common serial device nodes such as /dev/ttyUSB0
  camera   common V4L2 camera node such as /dev/video0
  audio    ALSA device access such as /dev/snd
  all      enable every overlay together
EOF
}

profile_arg() {
  local value="${1:-desktop}"
  case "${value}" in
    desktop|dev|sim)
      printf '%s\n' "${value}"
      ;;
    *)
      echo "unknown ANIMA profile: ${value}" >&2
      exit 1
      ;;
  esac
}

command_name="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${command_name}" in
  help|-h|--help)
    usage
    ;;
  up)
    exec "${ROOT_DIR}/scripts/start.sh" "$@"
    ;;
  build)
    profile="$(profile_arg "${1:-desktop}")"
    exec env ANIMA_PROFILE="${profile}" "${ROOT_DIR}/scripts/compose.sh" build
    ;;
  shell)
    exec "${ROOT_DIR}/scripts/shell.sh" "$@"
    ;;
  logs)
    profile="$(profile_arg "${1:-desktop}")"
    exec env ANIMA_PROFILE="${profile}" "${ROOT_DIR}/scripts/compose.sh" logs -f
    ;;
  stop)
    exec "${ROOT_DIR}/scripts/compose.sh" down
    ;;
  clean)
    exec "${ROOT_DIR}/scripts/compose.sh" down -v --remove-orphans
    ;;
  doctor)
    exec "${ROOT_DIR}/scripts/doctor.sh"
    ;;
  open)
    exec "${ROOT_DIR}/scripts/open.sh"
    ;;
  status)
    exec "${ROOT_DIR}/scripts/status.sh" "$(profile_arg "${1:-desktop}")"
    ;;
  url)
    exec "${ROOT_DIR}/scripts/url.sh"
    ;;
  env)
    exec "${ROOT_DIR}/scripts/env.sh"
    ;;
  password)
    exec "${ROOT_DIR}/scripts/password.sh" "${1:-show}"
    ;;
  foxglove)
    exec "${ROOT_DIR}/scripts/foxglove.sh" "$@"
    ;;
  demo)
    exec "${ROOT_DIR}/scripts/demo_workspace.sh" "$@"
    ;;
  starter)
    exec "${ROOT_DIR}/scripts/modules.sh" starter "$@"
    ;;
  module|modules)
    exec "${ROOT_DIR}/scripts/modules.sh" module "$@"
    ;;
  import)
    exec "${ROOT_DIR}/scripts/import_workspace.sh" "${1:-}"
    ;;
  export)
    exec "${ROOT_DIR}/scripts/export_workspace.sh" "${1:-}"
    ;;
  bake)
    exec docker buildx bake
    ;;
  compose)
    exec "${ROOT_DIR}/scripts/compose.sh" "$@"
    ;;
  sync-reference)
    exec "${ROOT_DIR}/scripts/sync_reference.sh"
    ;;
  install-cli)
    exec "${ROOT_DIR}/scripts/install.sh"
    ;;
  *)
    echo "unknown ANIMA command: ${command_name}" >&2
    usage >&2
    exit 1
    ;;
esac
