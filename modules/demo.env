MODULE_ID=demo
MODULE_TITLE="Workspace Readiness Starter"
MODULE_VERSION="1.0.0"
MODULE_SUMMARY="Installs the hello_anima starter package that proves the workspace is healthy and ready for new code."
MODULE_DESCRIPTION="${MODULE_SUMMARY}"
MODULE_SUPPORTED_DISTROS="humble:jazzy:rolling"
MODULE_SUPPORTED_PROFILES="desktop:dev:sim"
MODULE_DEPENDS=""
MODULE_SOURCE_PATHS="examples/robotflowlabs_anima_demo"
MODULE_INSTALL_TARGETS="robotflowlabs_anima_demo"
MODULE_RECOMMENDED_PROFILE="desktop"
MODULE_RUN_COMMAND="ros2 run robotflowlabs_anima_demo hello_anima"
MODULE_NEXT_STEPS="colcon build && source install/setup.bash && ros2 run robotflowlabs_anima_demo hello_anima"
MODULE_SMOKE_COMMAND="set +e; timeout 5 ros2 run robotflowlabs_anima_demo hello_anima >/tmp/robotflowlabs_anima_demo.log 2>&1; demo_status=\$?; set -e; if [[ \"\${demo_status}\" != \"0\" && \"\${demo_status}\" != \"124\" ]]; then cat /tmp/robotflowlabs_anima_demo.log >&2; exit \"\${demo_status}\"; fi; grep -q 'RobotFlowLabs ANIMA demo node started' /tmp/robotflowlabs_anima_demo.log"
