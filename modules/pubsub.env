MODULE_ID=pubsub
MODULE_TITLE="ROS 2 Graph Starter"
MODULE_VERSION="1.0.0"
MODULE_SUMMARY="Installs a talker/listener package that proves end-to-end ROS 2 message delivery."
MODULE_DESCRIPTION="${MODULE_SUMMARY}"
MODULE_SUPPORTED_DISTROS="humble:jazzy:rolling"
MODULE_SUPPORTED_PROFILES="desktop:dev:sim"
MODULE_DEPENDS=""
MODULE_SOURCE_PATHS="examples/robotflowlabs_anima_pubsub"
MODULE_INSTALL_TARGETS="robotflowlabs_anima_pubsub"
MODULE_NEXT_STEPS="colcon build && source install/setup.bash && ros2 launch robotflowlabs_anima_pubsub pubsub_demo.launch.py"
MODULE_SMOKE_COMMAND="set +e; timeout 8 ros2 launch robotflowlabs_anima_pubsub pubsub_demo.launch.py >/tmp/robotflowlabs_anima_pubsub.log 2>&1; module_status=\$?; set -e; if [[ \"\${module_status}\" != \"0\" && \"\${module_status}\" != \"124\" ]]; then cat /tmp/robotflowlabs_anima_pubsub.log >&2; exit \"\${module_status}\"; fi; grep -Eq 'Publishing ANIMA starter message|heard ANIMA starter message' /tmp/robotflowlabs_anima_pubsub.log"
