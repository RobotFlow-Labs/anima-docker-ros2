MODULE_ID=starter-sensors
MODULE_TITLE="Synthetic Sensors Starter"
MODULE_VERSION="1.0.0"
MODULE_SUMMARY="Installs a deterministic image-and-lidar publisher designed for Foxglove-first inspection without any external bag files or datasets."
MODULE_DESCRIPTION="${MODULE_SUMMARY}"
MODULE_SUPPORTED_DISTROS="humble:jazzy:rolling"
MODULE_SUPPORTED_PROFILES="dev:sim"
MODULE_DEPENDS=""
MODULE_SOURCE_PATHS="examples/robotflowlabs_anima_starter_sensors"
MODULE_INSTALL_TARGETS="robotflowlabs_anima_starter_sensors"
MODULE_RECOMMENDED_PROFILE="dev"
MODULE_RUN_COMMAND="ros2 launch robotflowlabs_anima_starter_sensors starter_sensors.launch.py"
MODULE_COMPANION_COMMAND="./anima foxglove dev"
MODULE_NEXT_STEPS="colcon build && source install/setup.bash && ros2 launch robotflowlabs_anima_starter_sensors starter_sensors.launch.py"
MODULE_SMOKE_COMMAND="set +e; timeout 10 ros2 launch robotflowlabs_anima_starter_sensors starter_sensors.launch.py >/tmp/robotflowlabs_anima_starter_sensors.log 2>&1; sensor_status=\$?; set -e; if [[ \"\${sensor_status}\" != \"0\" && \"\${sensor_status}\" != \"124\" ]]; then cat /tmp/robotflowlabs_anima_starter_sensors.log >&2; exit \"\${sensor_status}\"; fi; grep -q 'ANIMA synthetic sensors starter is publishing deterministic image and laser topics.' /tmp/robotflowlabs_anima_starter_sensors.log; grep -Eq 'Published deterministic sensor frame|Published startup sensor frame' /tmp/robotflowlabs_anima_starter_sensors.log"
