MODULE_ID=starter-sim
MODULE_TITLE="Gazebo Simulation Starter"
MODULE_VERSION="1.0.0"
MODULE_SUMMARY="Installs a reproducible Gazebo starter that opens on the noVNC desktop and confirms ROS graph activity through /clock."
MODULE_DESCRIPTION="${MODULE_SUMMARY}"
MODULE_SUPPORTED_DISTROS="humble:jazzy:rolling"
MODULE_SUPPORTED_PROFILES="sim"
MODULE_DEPENDS=""
MODULE_SOURCE_PATHS="examples/robotflowlabs_anima_starter_sim"
MODULE_INSTALL_TARGETS="robotflowlabs_anima_starter_sim"
MODULE_RECOMMENDED_PROFILE="sim"
MODULE_RUN_COMMAND="ros2 launch robotflowlabs_anima_starter_sim starter_sim.launch.py"
MODULE_COMPANION_COMMAND="./anima foxglove sim"
MODULE_NEXT_STEPS="colcon build && source install/setup.bash && ros2 launch robotflowlabs_anima_starter_sim starter_sim.launch.py"
MODULE_SMOKE_COMMAND="set +e; timeout 20 ros2 launch robotflowlabs_anima_starter_sim starter_sim.launch.py headless:=true >/tmp/robotflowlabs_anima_starter_sim.log 2>&1; sim_status=\$?; set -e; if [[ \"\${sim_status}\" != \"0\" && \"\${sim_status}\" != \"124\" ]]; then cat /tmp/robotflowlabs_anima_starter_sim.log >&2; exit \"\${sim_status}\"; fi; grep -q 'RobotFlowLabs ANIMA sim starter launching Gazebo' /tmp/robotflowlabs_anima_starter_sim.log; grep -q 'Bridging Gazebo clock onto /clock for ROS 2 tools.' /tmp/robotflowlabs_anima_starter_sim.log; grep -q 'ANIMA sim starter confirmed ROS graph activity on /clock.' /tmp/robotflowlabs_anima_starter_sim.log"
