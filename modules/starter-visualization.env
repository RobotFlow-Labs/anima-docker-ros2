MODULE_ID=starter-visualization
MODULE_TITLE="Flagship Visualization Starter"
MODULE_VERSION="1.0.0"
MODULE_SUMMARY="Installs the default first-run visualization flow: workspace readiness plus live ROS 2 pub/sub in one launch."
MODULE_DESCRIPTION="${MODULE_SUMMARY}"
MODULE_SUPPORTED_DISTROS="humble:jazzy:rolling"
MODULE_SUPPORTED_PROFILES="desktop:dev:sim"
MODULE_DEPENDS="demo:pubsub"
MODULE_SOURCE_PATHS="examples/robotflowlabs_anima_demo:examples/robotflowlabs_anima_pubsub:examples/robotflowlabs_anima_starter"
MODULE_INSTALL_TARGETS="robotflowlabs_anima_demo:robotflowlabs_anima_pubsub:robotflowlabs_anima_starter"
MODULE_NEXT_STEPS="colcon build && source install/setup.bash && ros2 launch robotflowlabs_anima_starter starter_demo.launch.py"
MODULE_SMOKE_COMMAND="set +e; timeout 10 ros2 launch robotflowlabs_anima_starter starter_demo.launch.py >/tmp/robotflowlabs_anima_starter.log 2>&1; starter_status=\$?; set -e; if [[ \"\${starter_status}\" != \"0\" && \"\${starter_status}\" != \"124\" ]]; then cat /tmp/robotflowlabs_anima_starter.log >&2; exit \"\${starter_status}\"; fi; grep -q 'RobotFlowLabs ANIMA demo node started' /tmp/robotflowlabs_anima_starter.log; grep -q 'Your workspace is ready. Add packages under /workspaces/anima/src.' /tmp/robotflowlabs_anima_starter.log; grep -q 'ANIMA starter talker is publishing on /anima/starter' /tmp/robotflowlabs_anima_starter.log; grep -Eq 'Publishing ANIMA starter message|heard ANIMA starter message' /tmp/robotflowlabs_anima_starter.log"
